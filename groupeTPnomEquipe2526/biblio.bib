@inproceedings{gg16,
 domainehal = {INFO:INFO_SE, INFO:INFO_MO},
 equipe = {vesontio},
 classement = {ACTN},
 title = {Spécification et vérification formelle d'opérations sur les permutations},
 author = {Genestier, Richard and Giorgetti, Alain},
 year = 2016,
 booktitle = {{AFADL'16}},
 pages = {72-78},
 note = {\url{http://events.femto-st.fr/sites/femto-st.fr.gdr-gpl-2016/files/content/AFADL-2016.pdf}},
 abstract = {
  Dans le cadre d'un projet plus vaste de formalisation de la combinatoire, nous
  présentons dans cet article deux opérations sur les permutations, leur
  implémentation en C sous forme de fonctions modifiant des tableaux
  d'entiers, et leur spécification formelle en ACSL. Après avoir spécifié des
  invariants de boucle adaptés, nous prouvons automatiquement
  que ces fonctions préservent les permutations, avec l'outil Frama-C et son
  greffon WP.
 }
}



@inproceedings{dgg16,
 domainehal = {INFO:INFO_SE, INFO:INFO_MO},
 equipe = {vesontio},
 classement = {ACTI},
 title = {Tests and Proofs for Enumerative Combinatorics},
 author = {Dubois, Catherine and Giorgetti, Alain and Genestier, Richard},
 year = 2016,
 booktitle = {{Tests and Proofs (TAP)}},
 address = {Vienna, Austria},
 series    = {Lecture Notes in Computer Science},
 volume = "6792",
 publisher="Springer International Publishing",
 pages="57--75",
 isbn="978-3-319-41135-4",
 doi="10.1007/978-3-319-41135-4_4",
 url="http://dx.doi.org/10.1007/978-3-319-41135-4_4",
 note = {https://hal.archives-ouvertes.fr/hal-01670709},
 abstract = {
  In this paper we show how the research domain of enumerative combinatorics can
  benefit from testing and formal verification. We formalize in Coq the
  combinatorial structures of permutations and maps, and a couple of related
  operations. Before formally proving soundness theorems about these operations,
  we first validate them, by using logic programming (Prolog) for bounded
  exhaustive testing and Coq/QuickChick for random testing.
  It is an experimental study preparing a more ambitious project about
  formalization of combinatorial results assisted by verification tools.},
}


